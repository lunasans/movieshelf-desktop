{
  "name": "movieshelf-desktop",
  "version": "0.9.1",
  "description": "MovieShelf Desktop – Filmsammlung lokal verwalten & mit deiner Shelf synchronisieren",
  "main": "dist-electron/main.js",
  "author": {
    "name": "Rene Neuhaus",
    "email": "app@movieshelf.info"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder",
    "preview": "vite preview",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@playwright/test": "^1.60.0",
    "@tanstack/vue-virtual": "^3.13.24",
    "adm-zip": "^0.5.17",
    "axios": "^1.16.0",
    "better-sqlite3": "^12.9.0",
    "bootstrap-icons": "^1.13.1",
    "electron-playwright-helpers": "^2.1.0",
    "electron-updater": "^6.8.3",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@vitejs/plugin-vue": "^6.0.6",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^41.5.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.3",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8",
    "wait-on": "^9.0.6"
  },
  "build": {
    "appId": "info.movieshelf.desktop",
    "productName": "MovieShelf",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.png"
    },
    "linux": {
      "target": [
        "deb"
      ],
      "icon": "public/icon.png",
      "category": "AudioVideo"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "lunasans",
        "repo": "movieshelf-desktop"
      }
    ]
  }
}

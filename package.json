{
  "name": "movieshelf-desktop",
  "version": "0.3.3",
  "description": "MovieShelf Desktop – Filmsammlung lokal verwalten & mit deiner Shelf synchronisieren",
  "main": "dist-electron/main.js",
  "author": {
    "name": "Rene Neuhaus",
    "email": "app@movieshelf.info"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "electron:dev": "vite",
    "electron:build": "vite build && electron-builder",
    "preview": "vite preview",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "better-sqlite3": "^12.9.0",
    "bootstrap-icons": "^1.13.1",
    "pinia": "^2.1.7",
    "vue": "^3.4.29",
    "vue-router": "^4.3.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@vitejs/plugin-vue": "^5.0.5",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.2.2",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.0.21",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "info.movieshelf.desktop",
    "productName": "MovieShelf",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.png"
    },
    "linux": {
      "target": ["deb"],
      "icon": "public/icon.png",
      "category": "AudioVideo"
    }
  }
}
